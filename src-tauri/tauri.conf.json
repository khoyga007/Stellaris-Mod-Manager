{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stellar Mod Manager",
  "version": "0.2.1",
  "identifier": "com.yang.stellarmodmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stellar Mod Manager",
        "width": 1280,
        "height": 820,
        "minWidth": 1000,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "center": true,
        "backgroundColor": "#0a0a0f",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
